<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard | EduSimplify AI — Adaptive Learning Companion</title>

    <!-- Bootstrap 5 -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <!-- Font Awesome -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    />
    <!-- IBM Plex Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <!-- Shared Site Styles -->
    <link rel="stylesheet" href="/css/style.css" />
    <!-- Dashboard-Specific Styles -->
    <link rel="stylesheet" href="/css/dashboard.css" />
  </head>
  <body class="es-app-body">
    <!-- ===================== NAVBAR (shared) ===================== -->
    <%- include("../includes/header.ejs", { navType: 'dashboard' }) %>

    <!-- ===================== MAIN APP ===================== -->
    <main class="es-dashboard">
      <div class="es-dashboard-container">
        <!-- ===================== SECTION 1: LEARNING INPUT WORKSPACE ===================== -->
        <section id="inputSection" class="alc-input-section" data-reveal>
          <div class="alc-input-card">
            <div class="alc-input-card-bg-orb"></div>
            <div class="alc-input-card-bg-orb alc-orb-2"></div>

            <div class="alc-input-head">
              <span class="es-eyebrow"
                ><i class="fa-solid fa-wand-magic-sparkles"></i>&nbsp;
                AI-Powered Adaptive Learning</span
              >
              <h1 class="alc-input-title">
                Turn Any Topic Into a<br /><span class="alc-title-accent"
                  >Personalized Learning Journey</span
                >
              </h1>
              <p class="alc-input-desc">
                Paste your course content, choose your level, and let your AI
                companion guide you — from a clear explanation to notes,
                flashcards, quizzes, and a full learning roadmap.
              </p>
              <div class="alc-input-chips">
                <span class="alc-chip"
                  ><i class="fa-solid fa-brain"></i> IBM Granite AI</span
                >
                <span class="alc-chip"
                  ><i class="fa-solid fa-bolt"></i> Instant Adaptation</span
                >
                <span class="alc-chip"
                  ><i class="fa-solid fa-shield-halved"></i> Watsonx.ai</span
                >
              </div>
            </div>

            <form id="learningForm" novalidate>
              <div class="mb-4">
                <label for="academicContent" class="alc-form-label">
                  <i class="fa-regular fa-file-lines me-2"></i>Academic Content
                </label>
                <textarea
                  class="form-control alc-textarea"
                  id="academicContent"
                  rows="8"
                  placeholder="Paste a textbook paragraph, lecture notes, research excerpt, or any educational content here…"
                  required
                ></textarea>
                <div class="invalid-feedback" id="contentError">
                  Please paste some academic content before generating.
                </div>
              </div>

              <div class="row g-3 align-items-end">
                <div class="col-md-7 col-lg-8">
                  <label for="learningLevel" class="alc-form-label">
                    <i class="fa-solid fa-layer-group me-2"></i>Learning Level
                  </label>
                  <div class="alc-level-selector" id="levelSelector">
                    <button
                      type="button"
                      class="alc-level-btn"
                      data-level="child"
                    >
                      <i class="fa-solid fa-child-reaching"></i> Child
                    </button>
                    <button
                      type="button"
                      class="alc-level-btn alc-level-active"
                      data-level="beginner"
                    >
                      <i class="fa-solid fa-seedling"></i> Beginner
                    </button>
                    <button
                      type="button"
                      class="alc-level-btn"
                      data-level="intermediate"
                    >
                      <i class="fa-solid fa-graduation-cap"></i> Intermediate
                    </button>
                    <button
                      type="button"
                      class="alc-level-btn"
                      data-level="expert"
                    >
                      <i class="fa-solid fa-user-graduate"></i> Expert
                    </button>
                  </div>
                  <input type="hidden" id="learningLevel" value="beginner" />
                </div>
                <div class="col-md-5 col-lg-4 d-grid">
                  <button
                    type="submit"
                    class="btn es-btn-primary btn-lg alc-generate-btn"
                    id="generateBtn"
                  >
                    <i class="fa-solid fa-wand-magic-sparkles me-2"></i>Generate
                    Learning Content
                  </button>
                </div>
              </div>
            </form>
          </div>
        </section>

        <!-- ===================== AI LOADING STATE ===================== -->
        <section id="loadingState" class="alc-loading d-none">
          <div class="alc-loader-wrap">
            <div class="alc-loader">
              <div class="alc-loader-ring"></div>
              <div class="alc-loader-ring alc-loader-ring-2"></div>
              <div class="alc-loader-ring alc-loader-ring-3"></div>
              <div class="alc-loader-core">
                <i class="fa-solid fa-brain"></i>
              </div>
            </div>
            <div class="alc-loader-steps" id="loaderStepsWrap">
              <div class="alc-loader-step alc-step-active" id="lstep-0">
                <i class="fa-solid fa-magnifying-glass"></i
                ><span>Analyzing Topic</span>
              </div>
              <div class="alc-loader-step" id="lstep-1">
                <i class="fa-solid fa-key"></i
                ><span>Identifying Key Concepts</span>
              </div>
              <div class="alc-loader-step" id="lstep-2">
                <i class="fa-solid fa-sliders"></i
                ><span>Personalizing Content</span>
              </div>
              <div class="alc-loader-step" id="lstep-3">
                <i class="fa-solid fa-sparkles"></i
                ><span>Generating Learning Experience</span>
              </div>
            </div>
          </div>
        </section>

        <!-- ===================== SECTION 2 & 3: EXPLANATION + SUMMARY ===================== -->
        <section id="coreOutputSection" class="alc-core-output d-none">
          <div class="alc-explanation-card" data-reveal>
            <div class="alc-card-header">
              <div class="alc-card-icon">
                <i class="fa-solid fa-compress"></i>
              </div>
              <div class="alc-card-header-text">
                <span class="alc-card-eyebrow"
                  >Step 1 of 3 &nbsp;&middot;&nbsp; AI Explanation</span
                >
                <h2 class="alc-card-title">Simplified Explanation</h2>
              </div>
              <span class="alc-level-badge ms-auto" id="explanationLevelBadge"
                ><i class="fa-solid fa-layer-group"></i> Beginner</span
              >
            </div>
            <div class="alc-divider"></div>
            <p class="alc-card-text" id="simplifiedExplanation"></p>
          </div>

          <div class="alc-summary-card" data-reveal>
            <div class="alc-card-header">
              <div class="alc-card-icon alc-card-icon-teal">
                <i class="fa-solid fa-align-left"></i>
              </div>
              <div class="alc-card-header-text">
                <span class="alc-card-eyebrow"
                  >Step 2 of 3 &nbsp;&middot;&nbsp; Key Takeaways</span
                >
                <h2 class="alc-card-title">Summary</h2>
              </div>
            </div>
            <div class="alc-divider"></div>
            <p class="alc-card-text" id="summaryText"></p>
          </div>
        </section>

        <!-- ===================== SECTION 4: AI LEARNING STUDIO ===================== -->
        <section
          id="continueLearningSection"
          class="alc-continue-section d-none"
        >
          <div class="alc-section-head" data-reveal>
            <span class="es-eyebrow"
              ><i class="fa-solid fa-flask"></i>&nbsp; Step 3 of 3
              &nbsp;&middot;&nbsp; AI Learning Studio</span
            >
            <h2 class="alc-section-title">
              Choose an AI Skill to Deepen Your Understanding
            </h2>
            <p class="alc-section-desc">
              Each card launches a unique AI-powered experience. Click any skill
              to generate instantly.
            </p>
          </div>

          <div class="alc-feature-grid" id="featureGrid" data-reveal>
            <button
              type="button"
              class="alc-feature-card"
              data-feature="revision"
            >
              <span class="alc-feature-arrow"
                ><i class="fa-solid fa-arrow-right"></i
              ></span>
              <div class="alc-feature-icon alc-fi-blue">
                <i class="fa-solid fa-book-bookmark"></i>
              </div>
              <h3 class="alc-feature-title">Revision Notes</h3>
              <p class="alc-feature-desc">
                Generate focused revision points for quick review and retention.
              </p>
            </button>

            <button
              type="button"
              class="alc-feature-card"
              data-feature="flashcards"
            >
              <span class="alc-feature-arrow"
                ><i class="fa-solid fa-arrow-right"></i
              ></span>
              <div class="alc-feature-icon alc-fi-indigo">
                <i class="fa-solid fa-layer-group"></i>
              </div>
              <h3 class="alc-feature-title">Flashcards</h3>
              <p class="alc-feature-desc">
                Interactive flip-card Q&amp;A pairs for active recall practice.
              </p>
            </button>

            <button type="button" class="alc-feature-card" data-feature="quiz">
              <span class="alc-feature-arrow"
                ><i class="fa-solid fa-arrow-right"></i
              ></span>
              <div class="alc-feature-icon alc-fi-teal">
                <i class="fa-solid fa-circle-question"></i>
              </div>
              <h3 class="alc-feature-title">Quiz Master</h3>
              <p class="alc-feature-desc">
                One-question-at-a-time quiz with score tracking and AI report.
              </p>
            </button>

            <button
              type="button"
              class="alc-feature-card"
              data-feature="roadmap"
            >
              <span class="alc-feature-arrow"
                ><i class="fa-solid fa-arrow-right"></i
              ></span>
              <div class="alc-feature-icon alc-fi-green">
                <i class="fa-solid fa-route"></i>
              </div>
              <h3 class="alc-feature-title">Learning Roadmap</h3>
              <p class="alc-feature-desc">
                Prerequisites checklist + step-by-step learning journey
                timeline.
              </p>
            </button>

            <button
              type="button"
              class="alc-feature-card"
              data-feature="realworld"
            >
              <span class="alc-feature-arrow"
                ><i class="fa-solid fa-arrow-right"></i
              ></span>
              <div class="alc-feature-icon alc-fi-orange">
                <i class="fa-solid fa-globe"></i>
              </div>
              <h3 class="alc-feature-title">Real World Explorer</h3>
              <p class="alc-feature-desc">
                Applications, industries, career relevance, and why this concept
                matters.
              </p>
            </button>

            <button
              type="button"
              class="alc-feature-card alc-feature-flagship"
              data-feature="compare-levels"
            >
              <span class="alc-flagship-badge"
                ><i class="fa-solid fa-star"></i> Featured AI Capability</span
              >
              <span class="alc-feature-arrow"
                ><i class="fa-solid fa-arrow-right"></i
              ></span>
              <div class="alc-feature-icon alc-fi-premium">
                <i class="fa-solid fa-scale-balanced"></i>
              </div>
              <h3 class="alc-feature-title">Compare Levels</h3>
              <p class="alc-feature-desc">
                See the same concept explained at Child, Beginner, Intermediate
                &amp; Expert depth.
              </p>
            </button>
          </div>

          <!-- Dynamic Feature Output Area -->
          <div id="featureOutputArea" class="alc-feature-output-area">
            <div class="alc-feature-panel d-none" id="panel-revision">
              <div class="alc-panel-header">
                <div class="alc-panel-header-left">
                  <div class="alc-card-icon alc-card-icon-sm">
                    <i class="fa-solid fa-book-bookmark"></i>
                  </div>
                  <div>
                    <span class="alc-panel-eyebrow">AI Learning Studio</span>
                    <h3 class="alc-panel-title">Revision Notes</h3>
                  </div>
                </div>
                <button type="button" class="alc-panel-close" data-close-panel>
                  <i class="fa-solid fa-xmark"></i>
                </button>
              </div>
              <div class="alc-notes-list" id="revisionNotesList"></div>
            </div>

            <div class="alc-feature-panel d-none" id="panel-flashcards">
              <div class="alc-panel-header">
                <div class="alc-panel-header-left">
                  <div class="alc-card-icon alc-card-icon-sm">
                    <i class="fa-solid fa-layer-group"></i>
                  </div>
                  <div>
                    <span class="alc-panel-eyebrow">AI Learning Studio</span>
                    <h3 class="alc-panel-title">Flashcards</h3>
                  </div>
                </div>
                <button type="button" class="alc-panel-close" data-close-panel>
                  <i class="fa-solid fa-xmark"></i>
                </button>
              </div>
              <div class="alc-fc-viewer">
                <div class="alc-fc-counter">
                  <span id="fcCurrentNum">1</span> /
                  <span id="fcTotalNum">1</span>
                </div>
                <div class="alc-flashcard-single" id="flashcardSingle">
                  <div class="alc-flashcard-inner" id="flashcardInner">
                    <div class="alc-flashcard-face alc-flashcard-front">
                      <span class="alc-flashcard-label"
                        ><i class="fa-regular fa-circle-question"></i>
                        Question</span
                      >
                      <p class="alc-flashcard-text" id="fcQuestion"></p>
                      <span class="alc-fc-tap-hint">Tap to reveal answer</span>
                    </div>
                    <div class="alc-flashcard-face alc-flashcard-back">
                      <span class="alc-flashcard-label"
                        ><i class="fa-solid fa-lightbulb"></i> Answer</span
                      >
                      <p class="alc-flashcard-text" id="fcAnswer"></p>
                    </div>
                  </div>
                </div>
                <div class="alc-fc-controls">
                  <button
                    type="button"
                    class="btn alc-fc-nav-btn"
                    id="fcPrevBtn"
                  >
                    <i class="fa-solid fa-chevron-left"></i> Previous
                  </button>
                  <button
                    type="button"
                    class="btn alc-fc-nav-btn"
                    id="fcNextBtn"
                  >
                    Next <i class="fa-solid fa-chevron-right"></i>
                  </button>
                </div>
              </div>
            </div>

            <div class="alc-feature-panel d-none" id="panel-quiz">
              <div class="alc-panel-header">
                <div class="alc-panel-header-left">
                  <div
                    class="alc-card-icon alc-card-icon-sm alc-card-icon-teal"
                  >
                    <i class="fa-solid fa-circle-question"></i>
                  </div>
                  <div>
                    <span class="alc-panel-eyebrow">AI Learning Studio</span>
                    <h3 class="alc-panel-title">Quiz Master</h3>
                  </div>
                </div>
                <button type="button" class="alc-panel-close" data-close-panel>
                  <i class="fa-solid fa-xmark"></i>
                </button>
              </div>
              <div id="quizInProgress">
                <div class="alc-quiz-meta">
                  <span class="alc-quiz-counter" id="quizCounter"
                    >Question 1 of 5</span
                  >
                  <span class="alc-quiz-score-live"
                    >Score: <strong id="quizScoreLive">0</strong></span
                  >
                </div>
                <div class="alc-quiz-progress">
                  <div
                    class="alc-quiz-progress-bar"
                    id="quizProgressBar"
                    style="width: 0%"
                  ></div>
                </div>
                <div class="alc-quiz-qblock" id="quizQBlock">
                  <p class="alc-quiz-question" id="quizQuestionText"></p>
                  <div class="alc-quiz-options" id="quizOptions"></div>
                </div>
                <div class="alc-quiz-actions">
                  <button
                    type="button"
                    class="btn es-btn-primary alc-quiz-next-btn"
                    id="quizNextBtn"
                    disabled
                  >
                    Next Question <i class="fa-solid fa-arrow-right ms-1"></i>
                  </button>
                </div>
              </div>
              <div id="quizReport" class="d-none">
                <div class="alc-report-hero">
                  <div class="alc-report-score-circle" id="reportScoreCircle">
                    <span id="reportScoreText">4/5</span>
                  </div>
                  <div class="alc-report-summary">
                    <h4 class="alc-report-heading" id="reportHeading">
                      Quiz Complete!
                    </h4>
                    <p class="alc-report-performance" id="reportPerformance">
                      Performance: <strong>Good</strong>
                    </p>
                  </div>
                </div>
                <div class="alc-report-body">
                  <div class="alc-report-col">
                    <h5 class="alc-report-col-title alc-col-green">
                      <i class="fa-solid fa-circle-check"></i> Strengths
                    </h5>
                    <ul class="alc-report-list" id="reportStrengths"></ul>
                  </div>
                  <div class="alc-report-col">
                    <h5 class="alc-report-col-title alc-col-red">
                      <i class="fa-solid fa-triangle-exclamation"></i> Needs
                      Improvement
                    </h5>
                    <ul
                      class="alc-report-list alc-report-list-weak"
                      id="reportWeaknesses"
                    ></ul>
                  </div>
                </div>
                <div
                  class="alc-report-recommendation"
                  id="reportRecommendation"
                >
                  <i class="fa-solid fa-wand-magic-sparkles alc-rec-icon"></i>
                  <div>
                    <span class="alc-rec-label">AI Recommendation</span>
                    <p class="alc-rec-text" id="recText"></p>
                  </div>
                </div>
                <div class="text-center mt-4">
                  <button
                    type="button"
                    class="btn es-btn-outline"
                    id="retakeQuizBtn"
                  >
                    <i class="fa-solid fa-rotate-left me-2"></i>Retake Quiz
                  </button>
                </div>
              </div>
            </div>

            <div class="alc-feature-panel d-none" id="panel-roadmap">
              <div class="alc-panel-header">
                <div class="alc-panel-header-left">
                  <div class="alc-card-icon alc-card-icon-sm">
                    <i class="fa-solid fa-route"></i>
                  </div>
                  <div>
                    <span class="alc-panel-eyebrow">AI Learning Studio</span>
                    <h3 class="alc-panel-title">Learning Roadmap</h3>
                  </div>
                </div>
                <button type="button" class="alc-panel-close" data-close-panel>
                  <i class="fa-solid fa-xmark"></i>
                </button>
              </div>
              <h4 class="alc-roadmap-section-title">
                <i class="fa-solid fa-clipboard-check me-2"></i>Before Learning
                This Topic
              </h4>
              <ul class="alc-prereq-list" id="prerequisitesList"></ul>
              <h4
                class="alc-roadmap-section-title alc-roadmap-section-title-mt"
              >
                <i class="fa-solid fa-map me-2"></i>Learning Journey
              </h4>
              <div class="alc-roadmap" id="learningPathContainer"></div>
            </div>

            <div class="alc-feature-panel d-none" id="panel-realworld">
              <div class="alc-panel-header">
                <div class="alc-panel-header-left">
                  <div
                    class="alc-card-icon alc-card-icon-sm alc-card-icon-orange"
                  >
                    <i class="fa-solid fa-globe"></i>
                  </div>
                  <div>
                    <span class="alc-panel-eyebrow">AI Learning Studio</span>
                    <h3 class="alc-panel-title">Real World Explorer</h3>
                  </div>
                </div>
                <button type="button" class="alc-panel-close" data-close-panel>
                  <i class="fa-solid fa-xmark"></i>
                </button>
              </div>
              <div class="alc-rw-grid" id="realWorldGrid"></div>
            </div>

            <div
              class="alc-feature-panel alc-panel-flagship d-none"
              id="panel-compare-levels"
            >
              <div class="alc-panel-header">
                <div class="alc-panel-header-left">
                  <div
                    class="alc-card-icon alc-card-icon-sm alc-card-icon-premium"
                  >
                    <i class="fa-solid fa-scale-balanced"></i>
                  </div>
                  <div>
                    <span class="alc-panel-eyebrow"
                      >AI Learning Studio &nbsp;&middot;&nbsp;
                      <span class="alc-flagship-text"
                        >Flagship Feature</span
                      ></span
                    >
                    <h3 class="alc-panel-title">Compare Levels</h3>
                  </div>
                </div>
                <button type="button" class="alc-panel-close" data-close-panel>
                  <i class="fa-solid fa-xmark"></i>
                </button>
              </div>
              <p class="alc-panel-sub">
                Follow the learning progression — from a child's introduction all the way to expert-level depth, with increasing complexity at each step.
              </p>
              <div class="alc-compare-grid" id="compareLevelsGrid"></div>
            </div>
          </div>

          <div class="text-center mt-5" data-reveal>
            <button
              type="button"
              class="btn es-btn-outline btn-lg px-5"
              id="resetBtn"
            >
              <i class="fa-solid fa-rotate-left me-2"></i>Start a New Topic
            </button>
          </div>
        </section>
      </div>
    </main>
    <%- include("../includes/footer.ejs") %>
    <!-- Bootstrap Bundle JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/script.js"></script>
    <script src="/js/dashboard.js"></script>
  </body>
</html>
