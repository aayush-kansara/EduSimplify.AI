<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EduSimplify AI — Adaptive Learning Powered by IBM Granite</title>

<!-- Bootstrap 5 -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
<!-- IBM Plex Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<!-- Custom Styles -->
<link rel="stylesheet" href="/css/style.css">
</head>
<body>

<!-- ===================== NAVBAR (shared) ===================== -->
<%- include("../includes/header.ejs", { navType: 'home' }) %>



<!-- ===================== HERO ===================== -->
<header id="top" class="es-hero">
  <div class="container">
    <div class="row align-items-center gy-5">

      <!-- Left: Copy -->
      <div class="col-lg-6" data-reveal>
        <span class="es-eyebrow"><i class="fa-solid fa-wand-magic-sparkles"></i>&nbsp; Powered by IBM Granite</span>
        <h1 class="es-hero-title">Transform Complex Learning into Simple Understanding</h1>
        <p class="es-hero-desc">
          EduSimplify AI turns dense academic content into explanations that actually make sense &mdash;
          tailored to your level, from Child to Expert. Paste your material, pick a level, and learn faster.
        </p>
        <div class="d-flex flex-wrap gap-3 mt-4">
          <a href="#get-started" class="btn es-btn-primary btn-lg px-4">
            Get Started <i class="fa-solid fa-arrow-right ms-2"></i>
          </a>
          <a href="#how-it-works" class="btn es-btn-outline btn-lg px-4">
            See How It Works
          </a>
        </div>
        <div class="es-hero-stats d-flex flex-wrap gap-4 mt-5">
          <div>
            <div class="es-stat-num">4</div>
            <div class="es-stat-label">Learning Levels</div>
          </div>
          <div>
            <div class="es-stat-num">5</div>
            <div class="es-stat-label">AI Outputs Per Request</div>
          </div>
          <div>
            <div class="es-stat-num">100%</div>
            <div class="es-stat-label">Free For Students</div>
          </div>
        </div>
      </div>

      <!-- Right: Signature "Live Transform" Demo Card -->
      <div class="col-lg-6" data-reveal data-reveal-delay="1">
        <div class="es-demo-card">
          <div class="es-demo-panel es-demo-input">
            <div class="es-demo-label">
              <i class="fa-regular fa-file-lines"></i>&nbsp; INPUT &middot; RAW ACADEMIC TEXT
            </div>
            <p class="es-demo-text">
              "Mitochondria are membrane-bound organelles that generate most of the cell's
              supply of adenosine triphosphate (ATP), used as a source of chemical energy."
            </p>
          </div>

          <div class="es-demo-arrow">
            <span class="es-demo-level-badge"><i class="fa-solid fa-layer-group"></i> Beginner Level</span>
            <i class="fa-solid fa-arrow-down-long"></i>
          </div>

          <div class="es-demo-panel es-demo-output">
            <div class="es-demo-label es-demo-label-output">
              <i class="fa-solid fa-lightbulb"></i>&nbsp; OUTPUT &middot; SIMPLIFIED
            </div>
            <p class="es-demo-text es-demo-text-output">
              Mitochondria are like tiny power plants inside your cells. They take in fuel
              and turn it into energy your body can actually use.
            </p>
            <div class="es-demo-tags">
              <span class="badge es-tag"><i class="fa-solid fa-check"></i> Summary</span>
              <span class="badge es-tag"><i class="fa-solid fa-check"></i> Key Concepts</span>
              <span class="badge es-tag"><i class="fa-solid fa-check"></i> Quiz</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</header>

<!-- ===================== FEATURES ===================== -->
<section id="features" class="es-section">
  <div class="container">
    <div class="es-section-head text-center" data-reveal>
      <span class="es-eyebrow">Core Features</span>
      <h2 class="es-section-title">Everything You Need to Understand Faster</h2>
      <p class="es-section-desc">One paste, five AI-generated outputs, built for every kind of learner.</p>
    </div>

    <div class="row g-4 mt-2">

      <div class="col-md-6 col-lg-4" data-reveal>
        <div class="es-feature-card">
          <div class="es-feature-icon"><i class="fa-solid fa-compress"></i></div>
          <h3 class="es-feature-title">Content Simplification</h3>
          <p class="es-feature-desc">Paste dense academic text and get a clear, easy-to-follow explanation instantly.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-4" data-reveal data-reveal-delay="1">
        <div class="es-feature-card">
          <div class="es-feature-icon"><i class="fa-solid fa-layer-group"></i></div>
          <h3 class="es-feature-title">Learner Level Selection</h3>
          <p class="es-feature-desc">Choose Child, Beginner, Intermediate, or Expert to match your understanding.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-4" data-reveal data-reveal-delay="2">
        <div class="es-feature-card">
          <div class="es-feature-icon"><i class="fa-solid fa-align-left"></i></div>
          <h3 class="es-feature-title">Summary Generator</h3>
          <p class="es-feature-desc">Get concise summaries that capture the core idea without the clutter.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-4" data-reveal>
        <div class="es-feature-card">
          <div class="es-feature-icon"><i class="fa-solid fa-diagram-project"></i></div>
          <h3 class="es-feature-title">Key Concepts Extraction</h3>
          <p class="es-feature-desc">Automatically pull out the most important terms and ideas to focus your study.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-4" data-reveal data-reveal-delay="1">
        <div class="es-feature-card">
          <div class="es-feature-icon"><i class="fa-solid fa-circle-question"></i></div>
          <h3 class="es-feature-title">Quiz Generator</h3>
          <p class="es-feature-desc">Test your understanding with auto-generated quiz questions based on the content.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-4" data-reveal data-reveal-delay="2">
        <div class="es-feature-card">
          <div class="es-feature-icon"><i class="fa-solid fa-lightbulb"></i></div>
          <h3 class="es-feature-title">Real-Life Example Generator</h3>
          <p class="es-feature-desc">See abstract concepts connected to everyday situations you already understand.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ===================== HOW IT WORKS ===================== -->
<section id="how-it-works" class="es-section es-section-alt">
  <div class="container">
    <div class="es-section-head text-center" data-reveal>
      <span class="es-eyebrow">The Process</span>
      <h2 class="es-section-title">How It Works</h2>
      <p class="es-section-desc">Four simple steps take you from confusing text to real understanding.</p>
    </div>

    <div class="row g-4 mt-2 es-steps">

      <div class="col-md-6 col-lg-3" data-reveal>
        <div class="es-step-card">
          <div class="es-step-num">01</div>
          <div class="es-step-icon"><i class="fa-solid fa-paste"></i></div>
          <h3 class="es-step-title">Paste Course Content</h3>
          <p class="es-step-desc">Drop in your textbook paragraph, lecture notes, or article.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-3" data-reveal data-reveal-delay="1">
        <div class="es-step-card">
          <div class="es-step-num">02</div>
          <div class="es-step-icon"><i class="fa-solid fa-sliders"></i></div>
          <h3 class="es-step-title">Choose Learning Level</h3>
          <p class="es-step-desc">Select Child, Beginner, Intermediate, or Expert.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-3" data-reveal data-reveal-delay="2">
        <div class="es-step-card">
          <div class="es-step-num">03</div>
          <div class="es-step-icon"><i class="fa-solid fa-robot"></i></div>
          <h3 class="es-step-title">Generate Simplified Content</h3>
          <p class="es-step-desc">IBM Granite instantly creates your tailored explanation.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-3" data-reveal data-reveal-delay="3">
        <div class="es-step-card">
          <div class="es-step-num">04</div>
          <div class="es-step-icon"><i class="fa-solid fa-graduation-cap"></i></div>
          <h3 class="es-step-title">Learn Faster</h3>
          <p class="es-step-desc">Review, quiz yourself, and retain what actually matters.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ===================== BENEFITS ===================== -->
<section id="benefits" class="es-section">
  <div class="container">
    <div class="es-section-head text-center" data-reveal>
      <span class="es-eyebrow">Why EduSimplify AI</span>
      <h2 class="es-section-title">Built for Every Kind of Learner</h2>
      <p class="es-section-desc">Designed for students, first-generation learners, and anyone learning in a second language.</p>
    </div>

    <div class="row g-4 mt-2">

      <div class="col-sm-6 col-lg-3" data-reveal>
        <div class="es-benefit-card">
          <div class="es-benefit-icon"><i class="fa-solid fa-brain"></i></div>
          <h3 class="es-benefit-title">Better Understanding</h3>
          <p class="es-benefit-desc">Complex ideas broken into language that clicks.</p>
        </div>
      </div>

      <div class="col-sm-6 col-lg-3" data-reveal data-reveal-delay="1">
        <div class="es-benefit-card">
          <div class="es-benefit-icon"><i class="fa-solid fa-people-group"></i></div>
          <h3 class="es-benefit-title">Inclusive Learning</h3>
          <p class="es-benefit-desc">Built for non-English backgrounds and first-gen learners.</p>
        </div>
      </div>

      <div class="col-sm-6 col-lg-3" data-reveal data-reveal-delay="2">
        <div class="es-benefit-card">
          <div class="es-benefit-icon"><i class="fa-solid fa-user-check"></i></div>
          <h3 class="es-benefit-title">Personalized Education</h3>
          <p class="es-benefit-desc">Content adapts to your exact learning level.</p>
        </div>
      </div>

      <div class="col-sm-6 col-lg-3" data-reveal data-reveal-delay="3">
        <div class="es-benefit-card">
          <div class="es-benefit-icon"><i class="fa-solid fa-clock"></i></div>
          <h3 class="es-benefit-title">Time Saving</h3>
          <p class="es-benefit-desc">Skip the struggle. Get to understanding in seconds.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ===================== CTA ===================== -->
<section id="get-started" class="es-cta">
  <div class="container text-center" data-reveal>
    <h2 class="es-cta-title">Ready to Understand Anything, Faster?</h2>
    <p class="es-cta-desc">Paste your first piece of course content and see it simplified in seconds.</p>
    <a href="/simplify" class="btn es-btn-light btn-lg px-5" id="get-started-btn">
      Get Started Free <i class="fa-solid fa-arrow-right ms-2"></i>
    </a>
  </div>
</section>

<!-- ===================== FOOTER ===================== -->
<%- include("../includes/footer.ejs") %>

<!-- Bootstrap Bundle JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>
</body>
</html>
