    <% } else { %>
      <!-- error / fallback: minimal right-side -->
      <div class="ms-auto d-flex align-items-center gap-2">
        <a href="/" class="btn es-btn-primary btn-sm px-3">
          <i class="fa-solid fa-house me-1"></i> Home
