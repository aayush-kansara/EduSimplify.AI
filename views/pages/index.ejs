<%- include("../includes/header.ejs", { navType: 'home' }) %>



<!-- ===================== HERO ===================== -->
<header id="top" class="es-hero">
  <div class="container">
    <div class="row align-items-center gy-5">

      <!-- Left: Copy -->
      <div class="col-lg-6" data-reveal>
        <span class="es-eyebrow"><i class="fa-solid fa-wand-magic-sparkles"></i>&nbsp;Powered by IBM watsonx.ai + Granite</span>
        <h1 class="es-hero-title">Transform Complex Learning into Simple Understanding</h1>
        <p class="es-hero-desc">
          EduSimplify AI turns dense academic content into explanations that actually make sense &mdash;
          tailored to your level, from Child to Expert. Paste your material, pick a level, and learn faster.
        </p>
        <div class="d-flex flex-wrap gap-3 mt-4">
          <a href="#get-started" class="btn es-btn-primary btn-lg px-4">
            Get Started <i class="fa-solid fa-arrow-right ms-2"></i>
          </a>
          <a href="#how-it-works" class="btn es-btn-outline btn-lg px-4">
            See How It Works
          </a>
        </div>
        <div class="es-hero-stats d-flex flex-wrap gap-4 mt-5">
          <div>
            <div class="es-stat-num">4</div>
            <div class="es-stat-label">Learning Levels</div>
          </div>
          <div>
            <div class="es-stat-num">7</div>
            <div class="es-stat-label">AI Learning Features</div>
          </div>
          <div>
            <div class="es-stat-num">100%</div>
            <div class="es-stat-label">Personalized Content</div>
          </div>
        </div>
      </div>

      <!-- Right: Signature "Live Transform" Demo Card -->
      <div class="col-lg-6" data-reveal data-reveal-delay="1">
        <div class="es-demo-card">
          <div class="es-demo-panel es-demo-input">
            <div class="es-demo-label">
              <i class="fa-regular fa-file-lines"></i>&nbsp; INPUT &middot; RAW ACADEMIC TEXT
            </div>
            <p class="es-demo-text">
              "Mitochondria are membrane-bound organelles that generate most of the cell's
              supply of adenosine triphosphate (ATP), used as a source of chemical energy."
            </p>
          </div>

          <div class="es-demo-arrow">
            <span class="es-demo-level-badge"><i class="fa-solid fa-layer-group"></i> Beginner Level</span>
            <i class="fa-solid fa-arrow-down-long"></i>
          </div>

          <div class="es-demo-panel es-demo-output">
            <div class="es-demo-label es-demo-label-output">
              <i class="fa-solid fa-lightbulb"></i>&nbsp; OUTPUT &middot; SIMPLIFIED
            </div>
            <p class="es-demo-text es-demo-text-output">
              Mitochondria are like tiny power plants inside your cells. They take in fuel
              and turn it into energy your body can actually use.
            </p>
            <div class="es-demo-tags">
              <span class="badge es-tag"><i class="fa-solid fa-check"></i> Summary</span>
              <span class="badge es-tag"><i class="fa-solid fa-check"></i> Key Concepts</span>
              <span class="badge es-tag"><i class="fa-solid fa-check"></i> Quiz</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</header>

<!-- ===================== FEATURES ===================== -->
<section id="features" class="es-section">
  <div class="container">
    <div class="es-section-head text-center" data-reveal>
      <span class="es-eyebrow">Core Features</span>
      <h2 class="es-section-title">Everything You Need for Smarter Learning</h2>
      <p class="es-section-desc">One topic, multiple AI-powered learning resources designed to improve understanding, retention, and concept mastery.</p>
    </div>

    <div class="row g-4 mt-2">

      <div class="col-md-6 col-lg-3" data-reveal>
        <div class="es-feature-card">
          <div class="es-feature-icon"><i class="fa-solid fa-brain"></i></div>
          <h3 class="es-feature-title">AI Content Simplification</h3>
          <p class="es-feature-desc">Transform complex academic content into learner-friendly explanations tailored to your proficiency level.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-3" data-reveal data-reveal-delay="1">
        <div class="es-feature-card">
          <div class="es-feature-icon"><i class="fa-solid fa-layer-group"></i></div>
          <h3 class="es-feature-title">Multi-Level Learning</h3>
          <p class="es-feature-desc">Learn the same concept as Child, Beginner, Intermediate, or Expert based on your understanding.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-3" data-reveal data-reveal-delay="2">
        <div class="es-feature-card">
          <div class="es-feature-icon"><i class="fa-regular fa-file-lines"></i></div>
          <h3 class="es-feature-title">Smart Summaries</h3>
          <p class="es-feature-desc">Generate concise summaries and revision-ready notes from lengthy educational content.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-3" data-reveal data-reveal-delay="3">
        <div class="es-feature-card">
          <div class="es-feature-icon"><i class="fa-regular fa-clone"></i></div>
          <h3 class="es-feature-title">Flashcards Generator</h3>
          <p class="es-feature-desc">Create AI-powered flashcards to reinforce key concepts and improve memory retention.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-3" data-reveal>
        <div class="es-feature-card">
          <div class="es-feature-icon"><i class="fa-solid fa-circle-question"></i></div>
          <h3 class="es-feature-title">Quiz Generator</h3>
          <p class="es-feature-desc">Test your understanding with automatically generated multiple-choice quizzes.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-3" data-reveal data-reveal-delay="1">
        <div class="es-feature-card">
          <div class="es-feature-icon"><i class="fa-solid fa-route"></i></div>
          <h3 class="es-feature-title">Learning Roadmaps</h3>
          <p class="es-feature-desc">Receive prerequisite concepts and structured learning paths for topic mastery.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-3" data-reveal data-reveal-delay="2">
        <div class="es-feature-card">
          <div class="es-feature-icon"><i class="fa-solid fa-lightbulb"></i></div>
          <h3 class="es-feature-title">Real-World Applications</h3>
          <p class="es-feature-desc">Understand how academic concepts are used in industries and everyday scenarios.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-3" data-reveal data-reveal-delay="3">
        <div class="es-feature-card">
          <div class="es-feature-icon"><i class="fa-solid fa-scale-balanced"></i></div>
          <h3 class="es-feature-title">Compare Levels</h3>
          <p class="es-feature-desc">Compare the same concept across four learning levels to visualize knowledge progression.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ===================== HOW IT WORKS ===================== -->
<section id="how-it-works" class="es-section es-section-alt">
  <div class="container">
    <div class="es-section-head text-center" data-reveal>
      <span class="es-eyebrow">The Process</span>
      <h2 class="es-section-title">How EduSimplify AI Works</h2>
      <p class="es-section-desc">Transform academic content into personalized learning resources in four simple steps.</p>
    </div>

    <div class="row g-4 mt-2 es-steps">

      <div class="col-md-6 col-lg-3" data-reveal>
        <div class="es-step-card">
          <div class="es-step-num">01</div>
          <div class="es-step-icon"><i class="fa-solid fa-paste"></i></div>
          <h3 class="es-step-title">Paste Academic Content</h3>
          <p class="es-step-desc">Enter textbook content, lecture notes, assignments, research material, or any academic topic.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-3" data-reveal data-reveal-delay="1">
        <div class="es-step-card">
          <div class="es-step-num">02</div>
          <div class="es-step-icon"><i class="fa-solid fa-sliders"></i></div>
          <h3 class="es-step-title">Select Learning Level</h3>
          <p class="es-step-desc">Choose Child, Beginner, Intermediate, or Expert based on your proficiency.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-3" data-reveal data-reveal-delay="2">
        <div class="es-step-card">
          <div class="es-step-num">03</div>
          <div class="es-step-icon"><i class="fa-solid fa-robot"></i></div>
          <h3 class="es-step-title">Generate Learning Resources</h3>
          <p class="es-step-desc">IBM Granite generates explanations, summaries, quizzes, flashcards, roadmaps, and more.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-3" data-reveal data-reveal-delay="3">
        <div class="es-step-card">
          <div class="es-step-num">04</div>
          <div class="es-step-icon"><i class="fa-solid fa-graduation-cap"></i></div>
          <h3 class="es-step-title">Learn &amp; Assess</h3>
          <p class="es-step-desc">Review generated resources, test your knowledge, and strengthen understanding.</p>
        </div>
      </div>

    </div>
  </div>
</section>

