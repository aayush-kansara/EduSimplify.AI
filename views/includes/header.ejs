          </li>
          <li class="nav-item">
            <a class="nav-link es-nav-link" href="#how-it-works">How It Works</a>
          </li>
          <li class="nav-item">
            <a class="nav-link es-nav-link" href="#benefits">Benefits</a>
          </li>
          <li class="nav-item ms-lg-2">
            <a href="/simplify" class="btn es-btn-primary btn-sm px-3">
              <i class="fa-solid fa-wand-magic-sparkles me-1"></i>Get Started
            </a>
          </li>
          <li class="nav-item ms-lg-1">
            <a
              href="https://github.com/aayush-kansara/EduSimplify.AI.git"
              class="nav-cta"
              target="_blank"
              rel="noopener noreferrer"
            >
              <i class="fa-brands fa-github"></i> GitHub Repo
            </a>
          </li>
        </ul>
      </div>

    <% } else if (navType === 'dashboard') { %>
      <!-- Mobile toggler -->
      <button
        class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#navMenu"
        aria-controls="navMenu"
        aria-expanded="false"
